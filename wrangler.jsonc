{
	"$schema": "node_modules/wrangler/config-schema.json",
	"name": "caldav",
	"main": "src/index.ts",
	"compatibility_date": "2026-01-26",
	"compatibility_flags": ["nodejs_compat"],
	"d1_databases": [
		{
			"binding": "DB",
			"database_name": "hono-caldav",
			"database_id": "256b87d7-86a1-400b-a19d-004796e611d2",
		},
	],
	"observability": {
		"enabled": true,
		"head_sampling_rate": 1,
	},
}
